# deploy/.env.example
#
# Copy to deploy/.env (or just run `just up` and one will be generated for
# you with a random ZTP_ADMIN_TOKEN). `.env` is gitignored.
#
# Promoting the local stack to production: change ZTP_SITE_ADDRESS to your
# real domain and ZTP_TLS_EMAIL to your ops email. Caddy will fetch a
# Let's Encrypt certificate automatically. Nothing else changes.

# Bearer token for the admin API. Generate with: openssl rand -hex 32
ZTP_ADMIN_TOKEN=

# Public hostname Caddy serves on.
#   localhost              — local dev (Caddy issues an internal-CA cert)
#   ztp.example.com        — production (Caddy fetches Let's Encrypt)
ZTP_SITE_ADDRESS=ztp.local

# TLS issuer.
#   internal               — Caddy local CA (for ZTP_SITE_ADDRESS=localhost)
#   ops@example.com        — Let's Encrypt account email (for a real domain)
ZTP_TLS_EMAIL=internal

# Host port that Caddy publishes HTTPS on.
ZTP_HTTPS_PORT=8443
