<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>ZTP</string>
    <key>CFBundleDisplayName</key>
    <string>ZTP</string>
    <key>CFBundleIdentifier</key>
    <string>io.thin-edge.ztp-app</string>
    <key>CFBundleVersion</key>
    <string>0.0.1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.0.1</string>
    <key>CFBundleExecutable</key>
    <string>ztp-app</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!--
        Required once PR 4 lands to add native BLE central. macOS will
        TCC-prompt the user the first time `tinygo.org/x/bluetooth`
        opens the central manager. Without this key the prompt never
        shows and the app sees zero peripherals — easy to misdiagnose
        as "BLE broken" on macOS.
    -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>ZTP uses Bluetooth to onboard nearby devices that advertise the ZTP service. Without this permission, BLE-capable devices cannot be enrolled from this Mac.</string>
</dict>
</plist>
